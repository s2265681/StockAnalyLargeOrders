# 数据库
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=stock

# ========== AI 多账号 ==========
# 默认账号：anyrouter | kalowave（推荐 kalowave）
AI_ACCOUNT=kalowave

# AnyRouter（Claude）
AI_ACCOUNT_ANYROUTER_KEY=sk-your-anyrouter-key
AI_ACCOUNT_ANYROUTER_URL=https://a-ocnfniawgw.cn-shanghai.fcapp.run
# AI_ACCOUNT_ANYROUTER_HAIKU=claude-haiku-4-5-20251001

# Kalowave（GPT）
AI_ACCOUNT_KALOWAVE_KEY=sk-your-kalowave-key
AI_ACCOUNT_KALOWAVE_URL=https://token.kalowave.com
# AI_ACCOUNT_KALOWAVE_OPUS=gpt-5.5      # 诊股、当天分析
# AI_ACCOUNT_KALOWAVE_SONNET=gpt-5.4    # 情绪周期、龙虎榜、追问
# AI_ACCOUNT_KALOWAVE_HAIKU=claude-haiku-4-5-20251001  # 涨停分组打标签

# 兼容旧变量（可选，anyrouter 会回退读取）
# CLAUDE_API_KEY=sk-your-anyrouter-key

# 定时任务邮件（盘前资讯 8:30 也会发到该邮箱，可用 MARKET_BRIEF_EMAIL 单独指定）
JOB_ALERT_EMAIL=your@email.com
MARKET_BRIEF_EMAIL=
JOB_NOTIFY_ON_SUCCESS=1
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SSL=1
SMTP_USER=your@email.com
SMTP_PASS=example
SMTP_FROM=your@email.com
